# ══════════════════════════════════════════════════════════════
# DeLiKet Environment Configuration
# ══════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/db

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-in-production

# ─── 🛡️ ESCROW — Payme Merchant API ─────────────────────────────
PAYME_MERCHANT_ID=your_merchant_id
PAYME_MERCHANT_KEY=your_merchant_key
PAYME_SANDBOX=true

# ─── 🛡️ ESCROW — Click.uz Merchant API ─────────────────────────
CLICK_SERVICE_ID=your_service_id
CLICK_MERCHANT_ID=your_merchant_id
CLICK_SECRET_KEY=your_secret_key
CLICK_SANDBOX=true

# ─── 💰 Nasiya/Installment ───────────────────────────────────────
# INSTALLMENT_ANNUAL_RATE_12=12

# ─── 🏛️ Fiskalizatsiya (Soliq nazorati) ─────────────────────────
# Payme Receipts API orqali O'zbekiston soliq tizimiga fiskal cheklarni yuborish
MERCHANT_STIR=your_tin_number
FISCAL_TERMINAL_ID=your_terminal_id

# ─── Telegram Bot ────────────────────────────────────────────────
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
WEBHOOK_SECRET_TOKEN=

# ─── Webhook URLs ────────────────────────────────────────────────
WEBHOOK_URL=https://delikat.vercel.app
WEB_URL=https://delikat.vercel.app

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
